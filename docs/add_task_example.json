{
  "about": "Example request/response formats for adding tasks to SQLite",
  "endpoint": "/api/tasks/taskadd",
  "method": "POST",
  "database": "appdata.db",
  "table": "tasks",
  "headers": {
    "Content-Type": "application/json"
  },
  "request_body_examples": [
    {
      "title": "Buy milk"
    },
    {
      "field": "Study Flask for 30 minutes"
    }
  ],
  "success_response_example": {
    "status": 201,
    "body": {
      "id": 1,
      "title": "Buy milk",
      "completed": false,
      "created_at": "2026-04-15 20:11:02"
    }
  },
  "error_response_examples": [
    {
      "status": 400,
      "body": {
        "error": "request body must be JSON"
      }
    },
    {
      "status": 400,
      "body": {
        "error": "title (or field) is required"
      }
    }
  ]
}
